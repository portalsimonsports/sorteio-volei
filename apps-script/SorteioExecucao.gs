/** Execução do sorteio e histórico */
function mapSorteio_(r,row){return{row,id:texto_(r[0]),status:texto_(r[1]||'INSCRICOES').toUpperCase(),codeHash:texto_(r[2]),codeFinal:texto_(r[3]),createdAt:r[4],activatedAt:r[5],scheduledAt:r[6],realizedAt:r[7],seed:texto_(r[8]),auditHash:texto_(r[9]),activatedBy:texto_(r[10]),message:texto_(r[11]),finalizedAt:r[12],championId:texto_(r[13])};}
function ultimoSorteio_(){const s=aba_(VOLEI.SHEETS.SORTEIOS),l=s.getLastRow();return l<2?null:mapSorteio_(s.getRange(l,1,1,14).getValues()[0],l);}
function realizarSorteioAgora_(origem){const b=lock_();b.waitLock(15000);try{const id=gerarId_('SOR'),agora=new Date();aba_(VOLEI.SHEETS.SORTEIOS).appendRow([id,'INSCRICOES','','',agora,'','','','','','ADMIN','Preparando sorteio.','','']);return realizarSorteioNaLinha_(ultimoSorteio_(),origem||'ADMIN');}finally{b.releaseLock();}}
function realizarSorteioNaLinha_(sorteio,origem){const equipes=formarEquipes_(),seed=sorteio.seed||Utilities.getUuid(),embaralhadas=embaralharDeterministico_(equipes,seed).map((e,i)=>Object.assign(e,{bracketOrder:i+1})),rounds=montarChaveamento_(embaralhadas,seed);gravarEquipes_(embaralhadas);gravarChaveamento_(sorteio.id,rounds);const audit=hash_(JSON.stringify({sorteioId:sorteio.id,seed,equipes:embaralhadas,rounds})),agora=new Date();aba_(VOLEI.SHEETS.SORTEIOS).getRange(sorteio.row,2,1,13).setValues([['SORTEADO',sorteio.codeHash,sorteio.codeFinal,sorteio.createdAt||agora,sorteio.activatedAt||agora,sorteio.scheduledAt||agora,agora,seed,audit,sorteio.activatedBy||origem,'Sorteio concluído. Equipes e chaveamento disponíveis.','','']]);log_('SORTEIO_REALIZADO',sorteio.id,origem,'SISTEMA','Equipes: '+equipes.length+' | Hash: '+audit,'INFO',sorteio.id);return{message:'Sorteio realizado.',teams:embaralhadas,rounds,auditHash:audit,state:obterEstadoPublicoSemVerificacao_()};}
function cancelarSorteio_(origem){const atual=ultimoSorteio_();if(!atual)throw Error('Nenhum sorteio registrado.');aba_(VOLEI.SHEETS.SORTEIOS).getRange(atual.row,2).setValue('CANCELADO');aba_(VOLEI.SHEETS.SORTEIOS).getRange(atual.row,12).setValue('Sorteio cancelado.');log_('SORTEIO_CANCELADO',atual.id,origem,'ADMIN','Cancelamento manual.','INFO',atual.id);return{message:'Sorteio cancelado.',state:obterEstadoAdmin_()};}
function resetarSorteio_(){limparAbaixoCabecalho_(VOLEI.SHEETS.EQUIPES,12);limparAbaixoCabecalho_(VOLEI.SHEETS.CHAVEAMENTO,24);const id=criarEstadoInscricoes_('Inscrições abertas.');log_('SORTEIO_RESETADO',id,'PAINEL_WEB','ADMIN','Equipes, placares e chaveamento limpos.','INFO',id);return{message:'Sorteio reiniciado.',state:obterEstadoAdmin_()};}
function limparTudo_(){limparAbaixoCabecalho_(VOLEI.SHEETS.JOGADORES,11);limparAbaixoCabecalho_(VOLEI.SHEETS.EQUIPES,12);limparAbaixoCabecalho_(VOLEI.SHEETS.CHAVEAMENTO,24);limparAbaixoCabecalho_(VOLEI.SHEETS.SORTEIOS,14);limparAbaixoCabecalho_(VOLEI.SHEETS.LOG,8);const id=criarEstadoInscricoes_('Todos os dados foram apagados. Inscrições abertas.');log_('DADOS_LIMPOS',id,'PAINEL_WEB','ADMIN','Participantes, equipes, chaveamento e histórico apagados.','ALERTA','SISTEMA');return{message:'Todos os dados foram apagados.',state:obterEstadoAdmin_()};}
