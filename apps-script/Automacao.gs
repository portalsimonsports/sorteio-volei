/** Acionador automático e diagnóstico */
function INSTALAR_ACIONADOR_AUTOMATICO(){ScriptApp.getProjectTriggers().forEach(t=>{if(t.getHandlerFunction()==='PROCESSAR_AUTOMACOES')ScriptApp.deleteTrigger(t);});ScriptApp.newTrigger('PROCESSAR_AUTOMACOES').timeBased().everyMinutes(1).create();definirConfig_('ACIONADOR_AUTOMATICO','ATIVO','Acionador de verificação a cada minuto');return{ok:true,mensagem:'Acionador instalado.'};}
function PROCESSAR_AUTOMACOES(){garantirEstrutura_();verificarContagem_();atualizarLiberacoes_();definirConfig_('ULTIMA_VERIFICACAO',new Date(),'Última verificação automática');return DIAGNOSTICO_SISTEMA();}
function DIAGNOSTICO_SISTEMA(){garantirEstrutura_();const j=lerJogadores_(),a=ultimoSorteio_();return{versao:VOLEI.VERSION,planilha:VOLEI.SPREADSHEET_ID,jogadores:j.length,adultosAtivos:j.filter(p=>p.active==='SIM'&&p.pot==='A').length,criancasAtivas:j.filter(p=>p.active==='SIM'&&p.pot==='B').length,equipes:lerEquipes_().length,jogos:Math.max(0,aba_(VOLEI.SHEETS.CHAVEAMENTO).getLastRow()-1),status:a?a.status:'INSCRICOES',webAppUrl:ScriptApp.getService().getUrl()||''};}
