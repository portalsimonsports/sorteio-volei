/** Acionador automático, agenda do evento e diagnóstico */
function INSTALAR_ACIONADOR_AUTOMATICO(){ScriptApp.getProjectTriggers().forEach(t=>{if(t.getHandlerFunction()==='PROCESSAR_AUTOMACOES')ScriptApp.deleteTrigger(t);});ScriptApp.newTrigger('PROCESSAR_AUTOMACOES').timeBased().everyMinutes(1).create();definirConfig_('ACIONADOR_AUTOMATICO','ATIVO','Acionador de verificação a cada minuto');return{ok:true,mensagem:'Acionador instalado.'};}
function iniciarContagemProgramada_(){const c=obterConfig_(),agora=new Date(),inicio=dataHoraEvento_(c.INICIO_CONTAGEM||'09:55'),partida=dataHoraEvento_(c.PRIMEIRA_PARTIDA_HORARIO||'10:15');if(agora.getTime()<inicio.getTime()||agora.getTime()>=partida.getTime())return false;const atual=ultimoSorteio_();if(atual&&['EM_CONTAGEM','SORTEADO','EM_ANDAMENTO','FINALIZADO'].indexOf(atual.status)>=0)return false;try{validarPotes_();}catch(err){log_('CONTAGEM_AGENDADA_PENDENTE','','AUTOMATICO','SISTEMA',mensagemErro_(err),'AVISO','AGENDA');return false;}const id=gerarId_('SOR');limparAbaixoCabecalho_(VOLEI.SHEETS.EQUIPES,12);limparAbaixoCabecalho_(VOLEI.SHEETS.CHAVEAMENTO,22);aba_(VOLEI.SHEETS.SORTEIOS).appendRow([id,'EM_CONTAGEM','','',agora,agora,partida,'','','','AUTOMATICO','Sorteio iniciado. Acompanhe a contagem regressiva.','','']);log_('CONTAGEM_INICIADA_AGENDA',id,'AUTOMATICO','SISTEMA','Início da contagem: '+formatarData_(inicio)+' | primeira partida: '+formatarData_(partida),'INFO',id);return true;}
function PROCESSAR_AUTOMACOES(){garantirEstrutura_();iniciarContagemProgramada_();verificarContagem_();atualizarLiberacoes_();definirConfig_('ULTIMA_VERIFICACAO',new Date(),'Última verificação automática');return DIAGNOSTICO_SISTEMA();}
function DIAGNOSTICO_SISTEMA(){garantirEstrutura_();const j=lerJogadores_(),a=ultimoSorteio_(),c=obterConfig_();return{versao:VOLEI.VERSION,planilha:VOLEI.SPREADSHEET_ID,jogadores:j.length,adultosAtivos:j.filter(p=>p.active==='SIM'&&p.pot==='A').length,criancasAtivas:j.filter(p=>p.active==='SIM'&&p.pot==='B').length,equipes:lerEquipes_().length,jogos:Math.max(0,aba_(VOLEI.SHEETS.CHAVEAMENTO).getLastRow()-1),status:a?a.status:'INSCRICOES',encerramentoInscricoes:texto_(c.ENCERRAMENTO_INSCRICOES),inicioContagem:texto_(c.INICIO_CONTAGEM),primeiraPartida:texto_(c.PRIMEIRA_PARTIDA_HORARIO),webAppUrl:ScriptApp.getService().getUrl()||''};}
