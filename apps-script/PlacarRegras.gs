/** Vôlei de quadra: melhor de 3 sets, 25/25/15 e vantagem de 2 */
function validarSet_(a,b,alvo,numeroSet){if(a==null||b==null)throw Error('Preencha a pontuação do '+numeroSet+'º set.');if(a<0||b<0||Math.floor(a)!==a||Math.floor(b)!==b)throw Error('A pontuação dos sets deve usar números inteiros não negativos.');if(a===b)throw Error('O '+numeroSet+'º set não pode terminar empatado.');if(Math.max(a,b)<alvo||Math.abs(a-b)<2)throw Error('Placar inválido no '+numeroSet+'º set. O vencedor precisa atingir '+alvo+' pontos e abrir vantagem mínima de 2.');return a>b?1:2;}
function validarPlacar_(s1a,s1b,s2a,s2b,s3a,s3b){const w1=validarSet_(s1a,s1b,25,1),w2=validarSet_(s2a,s2b,25,2);let sets1=(w1===1?1:0)+(w2===1?1:0),sets2=(w1===2?1:0)+(w2===2?1:0);if(sets1===1&&sets2===1){const w3=validarSet_(s3a,s3b,15,3);if(w3===1)sets1++;else sets2++;}else if((s3a!=null&&s3a!==0)||(s3b!=null&&s3b!==0))throw Error('O 3º set só deve ser preenchido quando a partida estiver empatada em 1 set a 1.');return{sets1,sets2,winnerSide:sets1===2?1:2};}
